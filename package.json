{
  "name": "meow-error",
  "displayName": "Meow Error",
  "description": "Plays a cute meow sound whenever a code error occurs in VS Code.",
  "version": "0.0.1",
  "publisher": "priyatosh-dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/Priyatosh11/meow-error"
  },
  "bugs": {
    "url": "https://github.com/Priyatosh11/meow-error/issues"
  },
  "homepage": "https://github.com/Priyatosh11/meow-error#readme",
  "license": "MIT",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "error",
    "sound",
    "meow",
    "fun",
    "productivity"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@types/node": "22.x",
    "@types/vscode": "^1.80.0",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "node-wav-player": "^1.0.0"
  }
}